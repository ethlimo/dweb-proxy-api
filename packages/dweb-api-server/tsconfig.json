{
  "extends": "../../tsconfig.base.json",
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "./src/**/*.spec.*"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}