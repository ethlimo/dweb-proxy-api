        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@eslint/compat": "^1.4.0",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.36.0",
        "@types/chai": "^4.3.5",
        "@types/mocha": "^10.0.1",
        "@types/node": "^20.3.1",
        "@types/sinon": "^17.0.2",
        "@types/sinon-chai": "^3.2.12",
        "@typescript-eslint/parser": "^8.45.0",
        "chai": "^4.3.7",
